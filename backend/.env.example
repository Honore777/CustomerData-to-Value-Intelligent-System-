# Example environment variables for backend (do NOT commit secrets to VCS)
# Copy this to .env and fill with production values before deploying.

DATABASE_URL=postgresql://user:password@host:5432/dbname
SECRET_KEY=replace-with-a-secure-random-string
FRONTEND_URL=https://your-frontend-url.vercel.app
ALLOWED_ORIGINS=https://your-frontend-url.vercel.app
COOKIE_DOMAIN=your-frontend-domain.com
COOKIE_SECURE=true

# Optional SMTP mailer (leave unset to skip sending emails)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-smtp-user
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=transeffex@gmail.com
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=Customer Churn Intelligent Prediction System

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/supermarket_ai
SECRET_KEY=replace-this-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=